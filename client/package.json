{
  "name": "neml2-langserv",
  "displayName": "NEML2",
  "description": "Syntax highlighting, completions, hover docs, and format-on-save for NEML2 input files",
  "//": "Reminder: this version is duplicated in /pyproject.toml and the LanguageServer constructor in /neml2_langserv/server.py. Keep all three in sync until we wire up a single source of truth.",
  "version": "0.3.0",
  "publisher": "hugary1995",
  "engines": {
    "vscode": "^1.82.0"
  },
  "icon": "icon.png",
  "categories": ["Programming Languages"],
  "repository": {
    "type": "git",
    "url": "https://github.com/applied-material-modeling/neml2-langserv.git"
  },
  "activationEvents": [
    "onLanguage:moose",
    "workspaceContains:**/*.i"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "neml2",
        "aliases": ["NEML2", "neml2"],
        "extensions": [],
        "firstLine": "^#\\s*neml2\\b",
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "neml2",
        "scopeName": "input.neml2",
        "path": "./syntaxes/neml2.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "neml2.inspectModel",
        "title": "Inspect Model",
        "category": "NEML2"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "neml2.inspectModel",
          "when": "editorLangId == neml2"
        }
      ]
    },
    "configuration": {
      "title": "NEML2",
      "properties": {
        "neml2.inspect.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show 'Inspect model' code lenses above each [model] block under [Models]. Requires neml2 ≥ 2.1.5."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run sync-readme && npm run compile",
    "sync-readme": "node -e \"require('fs').copyFileSync('../README.md', 'README.md')\"",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.82.0",
    "typescript": "^5.3.0"
  }
}
